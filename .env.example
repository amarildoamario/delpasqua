# DEV (sqlite)
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# IVA
VAT_RATE=0.04
PRICES_INCLUDE_VAT=false

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_LIVEMODE_EXPECTED=false

# App URL (dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# durata session admin (secondi)
ADMIN_SESSION_TTL_SECONDS=28800

# rotazione session (secondi)
ADMIN_SESSION_ROTATE_SECONDS=900

# per check Origin/Referer (prod)
APP_ORIGIN="https://tuodominio.it"

# Resend
RESEND_API_KEY="re_..."
EMAIL_FROM="Del Pasqua <noreply@tuodominio.it>"
EMAIL_REPLY_TO="tuo@email.it"
EMAIL_NOTIFY="tuo@email.it"
ADMIN_NOTIFY_EMAIL="tuo@email.it"

# Report admin
REPORT_SECRET="supersegreto"

# Admin credentials (metti valori veri solo nel tuo .env locale)
ADMIN_EMAIL="admin@tuodominio.it"
ADMIN_PASSWORD="cambia-questa-password"
ADMIN_SESSION_SECRET="genera-una-stringa-lunga-casuale"